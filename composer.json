{
    "name": "maccms/maccms10",
    "description": "Apple CMS V10 (MacCMS10) - dev/test tooling only. Production does NOT require Composer.",
    "type": "project",
    "license": "Apache-2.0",
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist"
    },
    "require": {
        "php": ">=7.4",
        "ext-mbstring": "*",
        "ext-pdo": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6"
    },
    "autoload-dev": {
        "psr-4": {
            "MaccmsTest\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit -c tests/phpunit.xml.dist",
        "test:unit": "phpunit -c tests/phpunit.xml.dist --testsuite Unit"
    },
    "scripts-descriptions": {
        "test": "Run the full PHPUnit test suite"
    }
}
