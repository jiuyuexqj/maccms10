# 上传目录禁止脚本执行（M3：即便上传白名单将来被绕过、落地 .php 也无法执行）
# 关闭 mod_php 解析
php_flag engine off
php_admin_flag engine off
# 直接拒绝脚本后缀
<FilesMatch "\.(php|php3|php4|php5|php7|phtml|pht|phar|cgi|pl|py|sh|asp|aspx|jsp|war)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
  </IfModule>
</FilesMatch>
