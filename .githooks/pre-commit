#!/usr/bin/env bash
# 提交门禁：跑通全部 PHPUnit 才允许 commit（见 CLAUDE.md §7.5、§10）
#
# 启用（每位开发者本地执行一次）：
#   git config core.hooksPath .githooks
#   # Unix 系需赋可执行权限：chmod +x .githooks/pre-commit
#
# 想跳过仅限紧急情况：git commit --no-verify （必须在 CI 补跑测试）

PHPUNIT="vendor/bin/phpunit"

# 1) PHPUnit 是否已安装
if [ ! -f "$PHPUNIT" ]; then
    echo "❌ 未安装 PHPUnit（找不到 $PHPUNIT）。" >&2
    echo "   请先运行: composer install" >&2
    echo "   紧急情况可 git commit --no-verify 跳过，但必须在 CI 补跑。" >&2
    exit 1
fi

# 2) PHP 是否可用
if ! command -v php >/dev/null 2>&1; then
    echo "❌ 当前环境找不到 php，无法运行测试。" >&2
    echo "   请在装有 PHP(>=7.4) 的环境提交；或 git commit --no-verify 跳过(须在 CI 补跑)。" >&2
    exit 1
fi

# 3) 跑全部单元测试
echo "▶ 提交门禁：运行全部单元测试..."
if ! php "$PHPUNIT" -c tests/phpunit.xml.dist; then
    echo "" >&2
    echo "❌ 测试未通过，提交已被阻止。请修复后重试。" >&2
    echo "   紧急情况可 git commit --no-verify 跳过，但必须在 CI 补跑。" >&2
    exit 1
fi

echo "✅ 全部测试通过，允许提交。"
exit 0
